# Example environment variables for the client (Vite)
# Copy this file to .env or .env.local and update values for your environment.
# Do NOT commit secrets — this file should contain only non-sensitive defaults.

VITE_API_URL=https://api.example.com
VITE_WS_URL=wss://ws.example.com
VITE_APP_NAME=MERN App
VITE_ENABLE_DEBUG=false
VITE_DEFAULT_LOCALE=en